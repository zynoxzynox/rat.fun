					Font = Enum.Font.Gotham,
					TextXAlignment = Enum.TextXAlignment.Left,
				}, el)

				local arrow = Make("TextLabel", {
					AnchorPoint = Vector2.new(1, 0.5),
					Position = UDim2.new(1, 0, 0.5, 0),
					Size = UDim2.new(0, 20, 0, 20),
					BackgroundTransparency = 1,
					Text = "›",
					TextColor3 = Theme.TextMuted,
					TextSize = 16,
					Font = Enum.Font.GothamBold,
					TextXAlignment = Enum.TextXAlignment.Center,
				}, el)

				local clickBtn = Make("TextButton", {
					Size = UDim2.new(1, 0, 1, 0),
					BackgroundTransparency = 1,
					Text = "",
				}, el)

				clickBtn.MouseEnter:Connect(function()
					Tween(el, { BackgroundColor3 = Theme.Border }, 0.15)
					Tween(arrow, { TextColor3 = Theme.Accent }, 0.15)
				end)
				clickBtn.MouseLeave:Connect(function()
					Tween(el, { BackgroundColor3 = Theme.SurfaceAlt }, 0.15)
					Tween(arrow, { TextColor3 = Theme.TextMuted }, 0.15)
				end)
				clickBtn.MouseButton1Click:Connect(function()
					Tween(el, { BackgroundColor3 = Theme.AccentDim }, 0.1)
					task.delay(0.12, function()
						Tween(el, { BackgroundColor3 = Theme.SurfaceAlt }, 0.15)
					end)
					if cfg.Callback then cfg.Callback() end
				end)
			end

			function Section:Toggle(cfg)
				cfg = cfg or {}
				local state = cfg.Default or false
				local el = MakeElement(36)

				local lbl = Make("TextLabel", {
					Position = UDim2.new(0, 0, 0, 0),
					Size = UDim2.new(1, -50, 1, 0),
					BackgroundTransparency = 1,
					Text = cfg.Title or "Toggle",
					TextColor3 = Theme.TextPrimary,
					TextSize = 12,
					Font = Enum.Font.Gotham,
					TextXAlignment = Enum.TextXAlignment.Left,
				}, el)

				local Track = Make("Frame", {
					AnchorPoint = Vector2.new(1, 0.5),
					Position = UDim2.new(1, 0, 0.5, 0),
					Size = UDim2.new(0, 36, 0, 19),
					BackgroundColor3 = state and Theme.ToggleOn or Theme.ToggleOff,
					BorderSizePixel = 0,
				}, el)
				MakeCorner(Track, 10)
				MakeStroke(Track, Theme.Border, 1)

				local Knob = Make("Frame", {
					AnchorPoint = Vector2.new(0, 0.5),
					Position = state and UDim2.new(0, 19, 0.5, 0) or UDim2.new(0, 2, 0.5, 0),
					Size = UDim2.new(0, 15, 0, 15),
					BackgroundColor3 = Color3.fromRGB(255, 255, 255),
					BorderSizePixel = 0,
				}, Track)
				MakeCorner(Knob, 8)

				local clickBtn = Make("TextButton", {
					Size = UDim2.new(1, 0, 1, 0),
					BackgroundTransparency = 1,
					Text = "",
				}, el)

				clickBtn.MouseButton1Click:Connect(function()
					state = not state
					Tween(Track, { BackgroundColor3 = state and Theme.ToggleOn or Theme.ToggleOff }, 0.2)
					Tween(Knob, { Position = state and UDim2.new(0, 19, 0.5, 0) or UDim2.new(0, 2, 0.5, 0) }, 0.2, Enum.EasingStyle.Back)
					if cfg.Callback then cfg.Callback(state) end
				end)

				return {
					Get = function() return state end,
					Set = function(v)
						state = v
						Tween(Track, { BackgroundColor3 = state and Theme.ToggleOn or Theme.ToggleOff }, 0.2)
						Tween(Knob, { Position = state and UDim2.new(0, 19, 0.5, 0) or UDim2.new(0, 2, 0.5, 0) }, 0.2, Enum.EasingStyle.Back)
					end
				}
			end

			function Section:Slider(cfg)
				cfg = cfg or {}
				local min = cfg.Min or 0
				local max = cfg.Max or 100
				local default = cfg.Default or min
				local value = default
				local el = MakeElement(52)
				el.Size = UDim2.new(1, 0, 0, 52)

				local top = Make("Frame", {
					Size = UDim2.new(1, 0, 0, 20),
					BackgroundTransparency = 1,
				}, el)

				Make("TextLabel", {
					Size = UDim2.new(0.7, 0, 1, 0),
					BackgroundTransparency = 1,
					Text = cfg.Title or "Slider",
					TextColor3 = Theme.TextPrimary,
					TextSize = 12,
					Font = Enum.Font.Gotham,
					TextXAlignment = Enum.TextXAlignment.Left,
				}, top)

				local valLabel = Make("TextLabel", {
					AnchorPoint = Vector2.new(1, 0),
					Position = UDim2.new(1, 0, 0, 0),
					Size = UDim2.new(0.3, 0, 1, 0),
					BackgroundTransparency = 1,
					Text = tostring(math.round(value)),
					TextColor3 = Theme.Accent,
					TextSize = 12,
					Font = Enum.Font.GothamBold,
					TextXAlignment = Enum.TextXAlignment.Right,
				}, top)

				local SliderTrack = Make("Frame", {
					Position = UDim2.new(0, 0, 0, 28),
					Size = UDim2.new(1, 0, 0, 6),
					BackgroundColor3 = Theme.Border,
					BorderSizePixel = 0,
				}, el)
				MakeCorner(SliderTrack, 4)

				local SliderFill = Make("Frame", {
					Size = UDim2.new((value - min) / (max - min), 0, 1, 0),
					BackgroundColor3 = Theme.Accent,
					BorderSizePixel = 0,
				}, SliderTrack)
				MakeCorner(SliderFill, 4)

				local SliderKnob = Make("Frame", {
					AnchorPoint = Vector2.new(0.5, 0.5),
					Position = UDim2.new((value - min) / (max - min), 0, 0.5, 0),
					Size = UDim2.new(0, 14, 0, 14),
					BackgroundColor3 = Color3.fromRGB(255, 255, 255),
					BorderSizePixel = 0,
					ZIndex = 2,
				}, SliderTrack)
				MakeCorner(SliderKnob, 7)

				local sliding = false

				local function UpdateSlider(inputX)
					local abs = SliderTrack.AbsolutePosition.X
					local width = SliderTrack.AbsoluteSize.X
					local pct = math.clamp((inputX - abs) / width, 0, 1)
					value = math.round(min + (max - min) * pct)
					valLabel.Text = tostring(value)
					Tween(SliderFill, { Size = UDim2.new(pct, 0, 1, 0) }, 0.05)
					Tween(SliderKnob, { Position = UDim2.new(pct, 0, 0.5, 0) }, 0.05)
					if cfg.Callback then cfg.Callback(value) end
				end

				local clickBtn = Make("TextButton", {
					Size = UDim2.new(1, 0, 1, 0),
					Position = UDim2.new(0, 0, 0, 0),
					BackgroundTransparency = 1,
					Text = "",
					ZIndex = 3,
				}, SliderTrack)

				clickBtn.MouseButton1Down:Connect(function(x)
					sliding = true
					UpdateSlider(x)
				end)

				UserInputService.InputChanged:Connect(function(input)
					if sliding and input.UserInputType == Enum.UserInputType.MouseMovement then
						UpdateSlider(input.Position.X)
					end
				end)

				UserInputService.InputEnded:Connect(function(input)
					if input.UserInputType == Enum.UserInputType.MouseButton1 then
						sliding = false
					end
				end)

				return {
					Get = function() return value end,
					Set = function(v)
						value = math.clamp(v, min, max)
						local pct = (value - min) / (max - min)
						valLabel.Text = tostring(value)
						Tween(SliderFill, { Size = UDim2.new(pct, 0, 1, 0) }, 0.15)
						Tween(SliderKnob, { Position = UDim2.new(pct, 0, 0.5, 0) }, 0.15)
					end
				}
			end

			function Section:Dropdown(cfg)
				cfg = cfg or {}
				local options = cfg.Options or {}
				local selected = cfg.Default or (options[1] or "Select")
				local open = false
				local el = MakeElement(36)

				Make("TextLabel", {
					Position = UDim2.new(0, 0, 0, 0),
					Size = UDim2.new(1, -60, 1, 0),
					BackgroundTransparency = 1,
					Text = cfg.Title or "Dropdown",
					TextColor3 = Theme.TextPrimary,
					TextSize = 12,
					Font = Enum.Font.Gotham,
					TextXAlignment = Enum.TextXAlignment.Left,
				}, el)

				local SelDisplay = Make("Frame", {
					AnchorPoint = Vector2.new(1, 0.5),
					Position = UDim2.new(1, 0, 0.5, 0),
					Size = UDim2.new(0, 100, 0, 24),
					BackgroundColor3 = Theme.Background,
					BorderSizePixel = 0,
				}, el)
				MakeCorner(SelDisplay, 5)
				MakeStroke(SelDisplay, Theme.Border, 1)
				MakePadding(SelDisplay, 0, 0, 8, 8)

				local selText = Make("TextLabel", {
					Size = UDim2.new(1, -16, 1, 0),
					BackgroundTransparency = 1,
					Text = selected,
					TextColor3 = Theme.TextSecondary,
					TextSize = 11,
					Font = Enum.Font.Gotham,
					TextXAlignment = Enum.TextXAlignment.Left,
					TextTruncate = Enum.TextTruncate.AtEnd,
				}, SelDisplay)

				local chevron = Make("TextLabel", {
					AnchorPoint = Vector2.new(1, 0.5),
					Position = UDim2.new(1, 0, 0.5, 0),
					Size = UDim2.new(0, 16, 1, 0),
					BackgroundTransparency = 1,
					Text = "▾",
					TextColor3 = Theme.TextMuted,
					TextSize = 10,
					Font = Enum.Font.GothamBold,
					TextXAlignment = Enum.TextXAlignment.Center,
				}, SelDisplay)

				local DropMenu = Make("Frame", {
					Position = UDim2.new(0, -12, 1, 6),
					Size = UDim2.new(1, 24, 0, 0),
					BackgroundColor3 = Theme.Surface,
					BorderSizePixel = 0,
					Visible = false,
					ZIndex = 20,
					ClipsDescendants = true,
				}, el)
				MakeCorner(DropMenu, 7)
				MakeStroke(DropMenu, Theme.Border, 1)
				MakeShadow(DropMenu)

				local DropList = Make("Frame", {
					Size = UDim2.new(1, 0, 0, 0),
					AutomaticSize = Enum.AutomaticSize.Y,
					BackgroundTransparency = 1,
				}, DropMenu)
				Make("UIListLayout", { SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 2) }, DropList)
				MakePadding(DropList, 4, 4, 4, 4)

				for _, opt in ipairs(options) do
					local optBtn = Make("TextButton", {
						Size = UDim2.new(1, 0, 0, 28),
						BackgroundColor3 = Theme.SurfaceAlt,
						BackgroundTransparency = 1,
						Text = opt,
						TextColor3 = opt == selected and Theme.Accent or Theme.TextSecondary,
						TextSize = 11,
						Font = Enum.Font.Gotham,
						BorderSizePixel = 0,
						ZIndex = 21,
					}, DropList)
					MakeCorner(optBtn, 5)
					MakePadding(optBtn, 0, 0, 8, 0)
					optBtn.TextXAlignment = Enum.TextXAlignment.Left

					optBtn.MouseEnter:Connect(function()
						Tween(optBtn, { BackgroundTransparency = 0 }, 0.1)
					end)
					optBtn.MouseLeave:Connect(function()
						Tween(optBtn, { BackgroundTransparency = 1 }, 0.1)
					end)
					optBtn.MouseButton1Click:Connect(function()
						selected = opt
						selText.Text = opt
						for _, c in ipairs(DropList:GetChildren()) do
							if c:IsA("TextButton") then
								Tween(c, { TextColor3 = Theme.TextSecondary }, 0.1)
							end
						end
						Tween(optBtn, { TextColor3 = Theme.Accent }, 0.1)
						open = false
						Tween(DropMenu, { Size = UDim2.new(1, 24, 0, 0) }, 0.2, Enum.EasingStyle.Quart)
						task.delay(0.2, function() DropMenu.Visible = false end)
						Tween(chevron, { Rotation = 0 }, 0.2)
						if cfg.Callback then cfg.Callback(selected) end
					end)
				end

				local targetHeight = #options * 30 + 8

				local clickBtn = Make("TextButton", {
					Size = UDim2.new(1, 0, 1, 0),
					BackgroundTransparency = 1,
					Text = "",
					ZIndex = 22,
				}, SelDisplay)

				clickBtn.MouseButton1Click:Connect(function()
					open = not open
					if open then
						DropMenu.Visible = true
						Tween(DropMenu, { Size = UDim2.new(1, 24, 0, targetHeight) }, 0.25, Enum.EasingStyle.Back)
						Tween(chevron, { Rotation = 180 }, 0.2)
					else
						Tween(DropMenu, { Size = UDim2.new(1, 24, 0, 0) }, 0.2, Enum.EasingStyle.Quart)
						task.delay(0.2, function() DropMenu.Visible = false end)
						Tween(chevron, { Rotation = 0 }, 0.2)
					end
				end)

				return {
					Get = function() return selected end,
					Set = function(v)
						selected = v
						selText.Text = v
					end
				}
			end

			function Section:Input(cfg)
				cfg = cfg or {}
				local el = MakeElement(58)
				el.Size = UDim2.new(1, 0, 0, 58)

				Make("TextLabel", {
					Size = UDim2.new(1, 0, 0, 20),
					BackgroundTransparency = 1,
					Text = cfg.Title or "Input",
					TextColor3 = Theme.TextPrimary,
					TextSize = 12,
					Font = Enum.Font.Gotham,
					TextXAlignment = Enum.TextXAlignment.Left,
				}, el)

				local InputBox = Make("Frame", {
					Position = UDim2.new(0, 0, 0, 24),
					Size = UDim2.new(1, 0, 0, 26),
					BackgroundColor3 = Theme.Background,
					BorderSizePixel = 0,
				}, el)
				MakeCorner(InputBox, 6)
				MakeStroke(InputBox, Theme.Border, 1)
				MakePadding(InputBox, 0, 0, 8, 8)

				local TextInput = Make("TextBox", {
					Size = UDim2.new(1, 0, 1, 0),
					BackgroundTransparency = 1,
					PlaceholderText = cfg.Placeholder or "Enter value...",
					PlaceholderColor3 = Theme.TextMuted,
					Text = cfg.Default or "",
					TextColor3 = Theme.TextPrimary,
					TextSize = 11,
					Font = Enum.Font.Gotham,
					TextXAlignment = Enum.TextXAlignment.Left,
					ClearTextOnFocus = false,
				}, InputBox)

				local stroke = InputBox:FindFirstChildOfClass("UIStroke")

				TextInput.Focused:Connect(function()
					Tween(stroke, { Color = Theme.Accent }, 0.2)
				end)

				TextInput.FocusLost:Connect(function(enter)
					Tween(stroke, { Color = Theme.Border }, 0.2)
					if cfg.Callback then cfg.Callback(TextInput.Text, enter) end
				end)

				return {
					Get = function() return TextInput.Text end,
					Set = function(v) TextInput.Text = v end
				}
			end

			function Section:Paragraph(cfg)
				cfg = cfg or {}
				local text = cfg.Content or ""
				local lines = math.max(1, math.ceil(#text / 45))
				local h = math.max(36, lines * 16 + 20)

				local el = MakeElement(h)
				el.Size = UDim2.new(1, 0, 0, h)

				if cfg.Title and cfg.Title ~= "" then
					Make("TextLabel", {
						Size = UDim2.new(1, 0, 0, 16),
						BackgroundTransparency = 1,
						Text = cfg.Title,
						TextColor3 = Theme.TextSecondary,
						TextSize = 11,
						Font = Enum.Font.GothamSemibold,
						TextXAlignment = Enum.TextXAlignment.Left,
					}, el)
				end

				Make("TextLabel", {
					Position = UDim2.new(0, 0, 0, cfg.Title and 18 or 0),
					Size = UDim2.new(1, 0, 1, cfg.Title and -18 or 0),
					BackgroundTransparency = 1,
					Text = text,
					TextColor3 = Theme.TextMuted,
					TextSize = 11,
					Font = Enum.Font.Gotham,
					TextXAlignment = Enum.TextXAlignment.Left,
					TextYAlignment = Enum.TextYAlignment.Top,
					TextWrapped = true,
				}, el)
			end

			table.insert(Tab._sections, Section)
			return Section
		end

		return Tab
	end

	return Window
end

return Library
