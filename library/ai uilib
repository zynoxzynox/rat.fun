			Tween(LoaderStatusText, { TextTransparency = 1 }, 0.2)
			task.delay(0.22, function()
				LoaderStatusText.Text = text
				Tween(LoaderStatusText, { TextTransparency = 0 }, 0.2)
			end)
			local progress = math.random(40, 85) / 100
			Tween(LoaderBarFill, { Size = UDim2.new(progress, 0, 1, 0) }, 0.6, Enum.EasingStyle.Quart)
		end

		function Loader:End()
			if not Loader._startDone then return end
			Loader._active = false

			Tween(LoaderBarFill, { Size = UDim2.new(1, 0, 1, 0) }, 0.4, Enum.EasingStyle.Quart)

			task.delay(0.5, function()
				if spinConn then spinConn:Disconnect() end

				Tween(LoaderTitle, { TextTransparency = 1 }, 0.35)
				Tween(LoaderSub, { TextTransparency = 1 }, 0.35)
				Tween(LoaderStatusText, { TextTransparency = 1 }, 0.35)
				Tween(SpinnerOuter, { GroupTransparency = 1 }, 0.35)
