			Tween(TabBtn, { BackgroundTransparency = 0 }, 0.2)
			Tween(TabLabel, { TextColor3 = Theme.TextPrimary }, 0.2)
			Tween(TabIndicator, { BackgroundTransparency = 0 }, 0.2)
		end

