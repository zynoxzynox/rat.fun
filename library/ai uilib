				Tween(prev._btn, { BackgroundTransparency = 1 }, 0.2)
				Tween(prev._label, { TextColor3 = Theme.TextMuted }, 0.2)
				Tween(prev._indicator, { BackgroundTransparency = 1 }, 0.2)
