			Loader._startDone = true
			Loader._active = true

			Tween(LoaderBarFill, { Size = UDim2.new(0.3, 0, 1, 0) }, 0.8, Enum.EasingStyle.Quad)

			spinConn = RunService.Heartbeat:Connect(function(dt)
				spinAngle = spinAngle + dt * 180
				if spinAngle >= 360 then spinAngle = spinAngle - 360 end
				SpinnerFill.Rotation = spinAngle
			end)
		end

